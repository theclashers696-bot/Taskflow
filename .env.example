# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL pooled connection (for Prisma queries)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true&connection_limit=1"

# Neon PostgreSQL direct connection (for Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret-32-chars-minimum"

# Full public URL of your app (e.g. https://yourdomain.vercel.app)
BETTER_AUTH_URL="https://yourdomain.vercel.app"

# Same URL accessible in the browser (prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_URL="https://yourdomain.vercel.app"

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# If left blank, the "Continue with Google" button is hidden automatically.
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Cloudinary (file uploads) ─────────────────────────────────────────────────
# Create a free account at https://cloudinary.com
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email / SMTP (optional — required for forgot-password emails) ─────────────
# If not set, forgot-password form UI works but no email is sent.
# Use an SMTP provider such as Resend, SendGrid, Mailgun, or Gmail App Password.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV="production"
